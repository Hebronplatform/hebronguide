{
  "buildCommand": "bash build.sh",
  "outputDirectory": "public",

  "redirects": [
    { "source": "/",                   "destination": "/seattle/", "permanent": false },
    { "source": "/seattle/index.html", "destination": "/seattle/", "permanent": true },
    { "source": "/dallas/index.html",  "destination": "/dallas/",  "permanent": true },
    { "source": "/sf/index.html",      "destination": "/sf/",      "permanent": true },
    { "source": "/home",               "destination": "/seattle/", "permanent": true },
    { "source": "/guide",              "destination": "/seattle/", "permanent": true }
  ],

  "rewrites": [
    { "source": "/seattle",        "destination": "/seattle/index.html" },
    { "source": "/seattle/(.*)",   "destination": "/seattle/index.html" },
    { "source": "/dallas",         "destination": "/dallas/index.html" },
    { "source": "/dallas/(.*)",    "destination": "/dallas/index.html" },
    { "source": "/sf",             "destination": "/sf/index.html" },
    { "source": "/sf/(.*)",        "destination": "/sf/index.html" },
    { "source": "/newyork",        "destination": "/newyork/index.html" },
    { "source": "/newyork/(.*)",   "destination": "/newyork/index.html" },
    { "source": "/nashville",      "destination": "/nashville/index.html" },
    { "source": "/nashville/(.*)", "destination": "/nashville/index.html" },
    { "source": "/boston",         "destination": "/boston/index.html" },
    { "source": "/boston/(.*)",    "destination": "/boston/index.html" },
    { "source": "/la",             "destination": "/la/index.html" },
    { "source": "/la/(.*)",        "destination": "/la/index.html" },
    { "source": "/toronto",        "destination": "/toronto/index.html" },
    { "source": "/toronto/(.*)",   "destination": "/toronto/index.html" },
    { "source": "/vancouver",      "destination": "/vancouver/index.html" },
    { "source": "/vancouver/(.*)", "destination": "/vancouver/index.html" }
  ],

  "headers": [
    {
      "source": "/(.*)/sw.js",
      "headers": [
        { "key": "Cache-Control",          "value": "no-cache, no-store, must-revalidate" },
        { "key": "Service-Worker-Allowed", "value": "/" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options",        "value": "DENY" },
        { "key": "X-XSS-Protection",       "value": "1; mode=block" },
        { "key": "X-Robots-Tag",           "value": "index, follow" }
      ]
    }
  ]
}
