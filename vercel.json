{
  "buildCommand": "bash build.sh",
  "outputDirectory": "public",

  "functions": {
    "api/ad-generator.js": { "maxDuration": 30 },
    "api/ask.js":          { "maxDuration": 30 }
  },

  "redirects": [
    { "source": "/",                   "destination": "/seattle/", "permanent": false },
    { "source": "/seattle/index.html", "destination": "/seattle/", "permanent": true },
    { "source": "/dallas/index.html",  "destination": "/dallas/",  "permanent": true },
    { "source": "/sf/index.html",      "destination": "/sf/",      "permanent": true },
    { "source": "/home",               "destination": "/seattle/", "permanent": true },
    { "source": "/guide",              "destination": "/seattle/", "permanent": true }
  ],

  "rewrites": [
    { "source": "/assets/(.*)",    "destination": "/seattle/assets/$1" },
    { "source": "/registerSW.js",  "destination": "/seattle/registerSW.js" },
    { "source": "/sw.js",          "destination": "/seattle/sw.js" },
    { "source": "/workbox-(.*)",   "destination": "/seattle/workbox-$1" },
    { "source": "/seattle",        "destination": "/seattle/index.html" },
    { "source": "/seattle/(.*)",   "destination": "/seattle/index.html" },
    { "source": "/dallas",         "destination": "/dallas/index.html" },
    { "source": "/dallas/(.*)",    "destination": "/dallas/index.html" },
    { "source": "/sf",             "destination": "/sf/index.html" },
    { "source": "/sf/(.*)",        "destination": "/sf/index.html" },
    { "source": "/newyork",        "destination": "/newyork/index.html" },
    { "source": "/newyork/(.*)",   "destination": "/newyork/index.html" },
    { "source": "/nashville",      "destination": "/nashville/index.html" },
    { "source": "/nashville/(.*)", "destination": "/nashville/index.html" },
    { "source": "/boston",         "destination": "/boston/index.html" },
    { "source": "/boston/(.*)",    "destination": "/boston/index.html" },
    { "source": "/la",             "destination": "/la/index.html" },
    { "source": "/la/(.*)",        "destination": "/la/index.html" },
    { "source": "/toronto",        "destination": "/toronto/index.html" },
    { "source": "/toronto/(.*)",   "destination": "/toronto/index.html" },
    { "source": "/vancouver",      "destination": "/vancouver/index.html" },
    { "source": "/vancouver/(.*)", "destination": "/vancouver/index.html" },
    { "source": "/houston",        "destination": "/houston/index.html" },
    { "source": "/houston/(.*)",   "destination": "/houston/index.html" },
    { "source": "/atlanta",        "destination": "/atlanta/index.html" },
    { "source": "/atlanta/(.*)",   "destination": "/atlanta/index.html" },
    { "source": "/kansascity",     "destination": "/kansascity/index.html" },
    { "source": "/kansascity/(.*)","destination": "/kansascity/index.html" },
    { "source": "/philadelphia",   "destination": "/philadelphia/index.html" },
    { "source": "/philadelphia/(.*)","destination": "/philadelphia/index.html" },
    { "source": "/miami",          "destination": "/miami/index.html" },
    { "source": "/miami/(.*)",     "destination": "/miami/index.html" },
    { "source": "/mexicocity",     "destination": "/mexicocity/index.html" },
    { "source": "/mexicocity/(.*)","destination": "/mexicocity/index.html" },
    { "source": "/guadalajara",    "destination": "/guadalajara/index.html" },
    { "source": "/guadalajara/(.*)","destination": "/guadalajara/index.html" },
    { "source": "/monterrey",      "destination": "/monterrey/index.html" },
    { "source": "/monterrey/(.*)", "destination": "/monterrey/index.html" }
  ],

  "headers": [
    {
      "source": "/(.*)/sw.js",
      "headers": [
        { "key": "Cache-Control",          "value": "no-cache, no-store, must-revalidate" },
        { "key": "Pragma",                 "value": "no-cache" },
        { "key": "Expires",               "value": "0" },
        { "key": "Service-Worker-Allowed", "value": "/" }
      ]
    },
    {
      "source": "/sw.js",
      "headers": [
        { "key": "Cache-Control",          "value": "no-cache, no-store, must-revalidate" },
        { "key": "Pragma",                 "value": "no-cache" },
        { "key": "Expires",               "value": "0" },
        { "key": "Service-Worker-Allowed", "value": "/" }
      ]
    },
    {
      "source": "/(.*)/registerSW.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "Pragma",        "value": "no-cache" },
        { "key": "Expires",       "value": "0" }
      ]
    },
    {
      "source": "/registerSW.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "Pragma",        "value": "no-cache" },
        { "key": "Expires",       "value": "0" }
      ]
    },
    {
      "source": "/(.*)/workbox-(.*).js",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "Pragma",        "value": "no-cache" },
        { "key": "Expires",       "value": "0" }
      ]
    },
    {
      "source": "/(.*)/index.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "Pragma",        "value": "no-cache" },
        { "key": "Expires",       "value": "0" },
        { "key": "Surrogate-Control", "value": "no-store" },
        { "key": "Vary", "value": "Accept-Encoding" }
      ]
    },
    {
      "source": "/(.*)/manifest.webmanifest",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "Content-Type",  "value": "application/manifest+json" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*)/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options",        "value": "DENY" },
        { "key": "X-XSS-Protection",       "value": "1; mode=block" },
        { "key": "X-Robots-Tag",           "value": "index, follow" }
      ]
    }
  ]
}
